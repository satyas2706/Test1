# .env.example
GEMINI_API_KEY=

# Email (Gmail SMTP Setup)
# 1. SMTP_HOST: smtp.gmail.com
# 2. SMTP_PORT: 587
# 3. SMTP_USER: your-email@gmail.com
# 4. SMTP_PASS: your-16-character-app-password
# 5. SMTP_FROM: your-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Twilio (SMS & WhatsApp Notifications)
# 1. TWILIO_ACCOUNT_SID: Found on your Twilio Console Dashboard
# 2. TWILIO_AUTH_TOKEN: Found on your Twilio Console Dashboard
# 3. TWILIO_PHONE_NUMBER: Your Twilio purchased number (for SMS)
# 4. TWILIO_WHATSAPP_NUMBER: Your Twilio WhatsApp-enabled number (often the same as above or a Sandbox number)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL
APP_URL=

# Branding
VITE_LOGO_URL=https://drive.google.com/uc?export=download&id=18DxK9dI0ubE_q1i_bsb0GXbpo7glmwcs
